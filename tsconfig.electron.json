{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "CommonJS",
    "moduleResolution": "node",
    "noEmit": false,
    "outDir": "dist/electron",
    "target": "ES2020",
    "lib": ["ES2020"],
    "types": ["node"],
    "skipLibCheck": true
  },
  "include": ["electron/**/*", "agent/**/*"],
  "exclude": ["node_modules", "dist", "src"]
}

